# Copy to scripts/deploy-gke.env, set values, then source it before deploying:
# source scripts/deploy-gke.env
export PROJECT_ID="your-gcp-project-id"
export REGION="us-central1"
export ZONE="us-central1-a"
export CLUSTER_NAME="finance-ai-test"
export ARTIFACT_REPOSITORY="finance-ai"
export IMAGE_TAG="1.0.0"

# Use: openssl rand -hex 24 and openssl rand -hex 32
export DATABASE_PASSWORD="replace-with-a-hex-password"
export APP_SECRET_KEY="replace-with-a-hex-secret"
export OPENAI_API_KEY=""
export OPENAI_MODEL="gpt-4.1-mini"

# ClusterIP avoids a billable public load balancer. Set to LoadBalancer to make
# the frontend public after deployment.
export FRONTEND_SERVICE_TYPE="ClusterIP"
export CORS_ORIGINS="http://localhost:8080"
