# PostgreSQL connection
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/finance_ai

# OpenAI integration
# Leave empty until a real API key is available.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Application settings
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

# Security
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60